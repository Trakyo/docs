{
  "$schema": "https://mintlify.com/docs.json",
  "basePath": "/docs",
  "theme": "mint",
  "name": "Trakyo",
  "colors": {
    "primary": "#0C8C5E",
    "light": "#18E299",
    "dark": "#0C8C5E"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/rate-limiting",
              "concepts/errors"
            ]
          },
          {
            "group": "Error Reference",
            "pages": [
              "errors/bad_request",
              "errors/unauthorized",
              "errors/key_expired",
              "errors/forbidden",
              "errors/not_found",
              "errors/conflict",
              "errors/rate_limited",
              "errors/internal_error"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Links",
            "pages": [
              "GET /links",
              "POST /links",
              "GET /links/{domainId}/{key}",
              "PATCH /links/{domainId}/{key}",
              "DELETE /links/{domainId}/{key}",
              "GET /links/{domainId}/{key}/clicks"
            ]
          },
          {
            "group": "Domains",
            "pages": [
              "GET /domains"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.trakyo.io",
          "icon": "chart-line"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@trakyo.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.trakyo.io"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"]
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/taborintrakyo"
    }
  }
}
